generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  pseudo    String   @unique
  password  String
  birthDate DateTime?
  avatar    String?  @default("👤")
  createdAt DateTime @default(now())
}